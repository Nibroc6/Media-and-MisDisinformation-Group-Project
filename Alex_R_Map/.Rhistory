library(networkD3)
library(htmlwidgets)
library(jsonlite)
# Nodes
Players <- data.frame(
name = c(
"Donald Trump",
"Robert F. Kennedy Jr.",
"Laura Loomer",
"Matt Gaetz",
"Dr. Robert Malone",
"Dr. Marty Makary",
"Children's Health Defense",
"Dr. William Parker",
"Dr. Jay Bhattacharya",
"Dr. Mehmet Oz",
"Nick Sortor",
"Alex Clark",
"Moms Across America",
"Joe Rogan",
"The Wall Street Journal",
"Bloomberg TV",
"Fox News",
"The Daily Caller",
"Infowars",
"Dr. Andrea Baccarelli",
"Harvard School of Public Health",
"The Atlantic"
),
group = c(
"Executive Branch",
"Executive Branch",
"Influencer",
"Influencer",
"Executive Branch",
"Executive Branch",
"Non-Government Organization",
"Researcher",
"Executive Branch",
"Executive Branch",
"Influencer",
"Influencer",
"Non-Government Organization",
"Influencer",
"Press",
"Press",
"Press",
"Press",
"Press",
"Researcher",
"Non-Government Organization",
"Press"
)
)
# Edges
Edges <- data.frame(
source = c(
0, 1, 5, 1, 1,
1, 1, 2, 8, 19, 18,
2, 2, 2, 2, 3, 10, 13, 6,
14, 18, 18, 15, 5,
5, 5, 16, 17, 1,
21, 21, 21,
11, 12
),
target = c(
1, 5, 4, 8, 9,
6, 7, 7, 7, 20, 13,
0, 1, 16, 7, 4, 1, 20, 14,
1, 14, 1, 5, 14,
19, 16, 9, 1, 17,
1, 7, 8,
5, 5
),
value = 1,
color = c(
"#ef476f", "#ef476f", "#ef476f", "#ef476f", "#ef476f",
"#ffd166", "#dabfff", "#dabfff", "#dabfff", "#ef476f", "#ef476f",
"#06d6a0", "#06d6a0", "#06d6a0", "#dabfff", "#dabfff", "#06d6a0", "#06d6a0", "#26547c",
"#26547c", "#26547c", "#26547c", "#dabfff", "#26547c",
"#06d6a0", "#26547c", "#dabfff", "#26547c", "#06d6a0",
"#26547c", "#26547c", "#26547c",
"#06d6a0", "#26547c"
)
)
p <- forceNetwork(
Links       = Edges,
Nodes       = Players,
Source      = "source",
Target      = "target",
Value       = "value",
NodeID      = "name",
Group       = "group",
fontSize    = 12,
fontFamily  = "sans-serif",
opacity     = 0.9,
colourScale = JS("d3.scaleOrdinal(d3.schemeCategory10);"),
zoom        = TRUE,
arrows      = TRUE,
legend      = FALSE
)
p <- onRender(p, sprintf('
function(el, x) {
var colors = %s;
setTimeout(function() {
var svg = d3.select(el).select("svg");
var defs = svg.select("defs");
// Clone existing marker for each unique color
var existingMarker = defs.select("marker");
var uniqueColors = [...new Set(colors)];
uniqueColors.forEach(function(color) {
var newId = "arrow-" + color.replace("#", "");
var clone = existingMarker.node().cloneNode(true);
clone.setAttribute("id", newId);
var path = clone.querySelector("path, polygon");
if (path) {
path.setAttribute("fill", color);
path.setAttribute("stroke", color);
}
defs.node().appendChild(clone);
});
// Apply stroke color and matching marker to each link
svg.selectAll(".link")
.style("stroke", function(d, i) { return colors[i]; })
.style("stroke-opacity", 0.75)
.style("stroke-width", 1.8)
.attr("marker-end", function(d, i) {
return "url(#arrow-" + colors[i].replace("#", "") + ")";
});
var padding     = 10;
var titleHeight = 24;
var rowHeight   = 22;
var circleR     = 6;
var lineLen     = 24;
var boxWidth    = 260;
// --- Node legend data ---
var nodeLegend = [
{ label: "Executive Branch",            color: "#1f77b4" },
{ label: "Influencer",                  color: "#ff7f0e" },
{ label: "Non-Government Organization", color: "#2ca02c" },
{ label: "Press",                       color: "#d62728" },
{ label: "Researcher",                  color: "#9467bd" }
];
var nodeBoxHeight = padding * 2 + titleHeight + rowHeight * nodeLegend.length;
var nodeLegendG = svg.append("g")
.attr("transform", "translate(10, 10)");
nodeLegendG.append("rect")
.attr("width", boxWidth)
.attr("height", nodeBoxHeight)
.attr("rx", 4)
.attr("fill", "white")
.attr("fill-opacity", 0.85)
.attr("stroke", "#ccc")
.attr("stroke-width", 0.5);
nodeLegendG.append("text")
.attr("x", padding)
.attr("y", padding + 12)
.attr("font-size", "12px")
.attr("font-weight", "bold")
.attr("font-family", "sans-serif")
.attr("fill", "#333")
.text("Node Type");
nodeLegendG.append("line")
.attr("x1", padding)
.attr("y1", padding + 18)
.attr("x2", boxWidth - padding)
.attr("y2", padding + 18)
.attr("stroke", "#ccc")
.attr("stroke-width", 0.5);
nodeLegend.forEach(function(d, i) {
var rowY = padding + titleHeight + 10 + i * rowHeight;
var row = nodeLegendG.append("g")
.attr("transform", "translate(" + padding + "," + rowY + ")");
row.append("circle")
.attr("cx", circleR)
.attr("cy", 6)
.attr("r", circleR)
.attr("fill", d.color);
row.append("text")
.attr("x", circleR * 2 + 8)
.attr("y", 10)
.attr("font-size", "11px")
.attr("font-family", "sans-serif")
.attr("fill", "#333")
.text(d.label);
});
// --- Edge legend ---
var edgeLegend = [
{ label: "Current professional association",     color: "#ef476f" },
{ label: "Past professional association",        color: "#ffd166" },
{ label: "Reported on",                          color: "#26547c" },
{ label: "Posted about",                         color: "#06d6a0" },
{ label: "Platformed/Received Information From", color: "#dabfff" }
];
var edgeBoxHeight = padding * 2 + titleHeight + rowHeight * edgeLegend.length;
var edgeLegendG = svg.append("g")
.attr("transform", "translate(10, " + (nodeBoxHeight + 20) + ")");
edgeLegendG.append("rect")
.attr("width", boxWidth)
.attr("height", edgeBoxHeight)
.attr("rx", 4)
.attr("fill", "white")
.attr("fill-opacity", 0.85)
.attr("stroke", "#ccc")
.attr("stroke-width", 0.5);
edgeLegendG.append("text")
.attr("x", padding)
.attr("y", padding + 12)
.attr("font-size", "12px")
.attr("font-weight", "bold")
.attr("font-family", "sans-serif")
.attr("fill", "#333")
.text("Edge Type");
edgeLegendG.append("line")
.attr("x1", padding)
.attr("y1", padding + 18)
.attr("x2", boxWidth - padding)
.attr("y2", padding + 18)
.attr("stroke", "#ccc")
.attr("stroke-width", 0.5);
edgeLegend.forEach(function(d, i) {
var rowY = padding + titleHeight + 10 + i * rowHeight;
var row = edgeLegendG.append("g")
.attr("transform", "translate(" + padding + "," + rowY + ")");
row.append("line")
.attr("x1", 0).attr("y1", 6)
.attr("x2", lineLen).attr("y2", 6)
.attr("stroke", d.color)
.attr("stroke-width", 2.5);
row.append("polygon")
.attr("points", "0,-4 8,0 0,4")
.attr("transform", "translate(" + lineLen + ", 6)")
.attr("fill", d.color);
row.append("text")
.attr("x", lineLen + 12)
.attr("y", 10)
.attr("font-size", "11px")
.attr("font-family", "sans-serif")
.attr("fill", "#333")
.text(d.label);
});
}, 500);
}
', jsonlite::toJSON(Edges$color, auto_unbox = TRUE)))
p
