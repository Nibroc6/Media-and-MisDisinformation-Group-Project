digraph follow_network {
  rankdir=LR;
  graph [fontname="Helvetica"];
  node [shape=ellipse, style=filled, fillcolor="#f6f8fa", color="#8c959f", fontname="Helvetica"];
  edge [color="#57606a", fontname="Helvetica"];
  "DonaldJTrumpJr" [label="Donald Trump Jr.\n@DonaldJTrumpJr", fillcolor="#d1fae5"];
  "Jim_Jordan" [label="Rep. Jim Jordan\n@Jim_Jordan", fillcolor="#d1fae5"];
  "realDonaldTrump" [label="Donald J. Trump\n@realDonaldTrump", fillcolor="#ffd8a8"];
  "realDonaldTrump" -> "DonaldJTrumpJr" [color="#1f6feb"];
  "realDonaldTrump" -> "Jim_Jordan" [color="#1f6feb"];
  "DonaldJTrumpJr" -> "Jim_Jordan" [color="#2da44e"];
  "Jim_Jordan" -> "DonaldJTrumpJr" [color="#2da44e"];
}
